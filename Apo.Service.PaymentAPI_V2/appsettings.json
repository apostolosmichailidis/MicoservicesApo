{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=Apo_Payment;Trusted_Connection=True"
    },
    "ApiSettings": {
        "JwtOptionsForAssymetricES256": {
            "Issuer": "your-issuer",
            "Audience": "your-audience",
            "PublicKeyPath": "./keys/public.pem"
        }
    },
    "StripeSettings": {
        "SecretKey": "your-stripe-secret-key",
        "WebhookSecret": "your-stripe-webhook-secret"
    }
}
