{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=Apo_Auth;Trusted_Connection=True"
    },
    "ApiSettings": {
        "JwtOptionsForSymmetricHmacSha256": {
            "Secret": "THIS IS THE SECRET TO GENERATE JWT TOKEN",
            "Issuer": "apo-auth-api",
            "Audience": "apo-auth-client"
        },
        "JwtOptionsForAssymetricES256": {
            "Issuer": "your-issuer",
            "Audience": "your-audience",
            "PrivateKeyPath": "./keys/private.pem",
            "PublicKeyPath": "./keys/public.pem"
        }
    }
}
